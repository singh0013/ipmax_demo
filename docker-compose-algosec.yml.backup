services:
  db:
    image: postgres:16-alpine
    container_name: ipam_db
    restart: unless-stopped
    environment:
      POSTGRES_DB:       ${POSTGRES_DB:-ipam}
      POSTGRES_USER:     ${POSTGRES_USER:-ipam_user}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-ipam_pass}
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./db/init.sql:/docker-entrypoint-initdb.d/init.sql
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-ipam_user} -d ${POSTGRES_DB:-ipam}"]
      interval: 10s
      timeout: 5s
      retries: 5

  backend:
    build: ./backend
    container_name: ipam_backend
    restart: unless-stopped
    privileged: true        # Required for ICMP ping discovery
    network_mode: host      # Direct network access for ping sweep
    environment:
      DATABASE_URL: postgresql://${POSTGRES_USER:-ipam_user}:${POSTGRES_PASSWORD:-ipam_pass}@localhost:5432/${POSTGRES_DB:-ipam}
      SECRET_KEY: ${SECRET_KEY:-change-this-in-production}
    depends_on:
      db:
        condition: service_healthy
    volumes:
      - ./backend:/app

  frontend:
    build: ./frontend
    container_name: ipam_frontend
    restart: unless-stopped
    depends_on:
      - backend
    ports:
      - "${IPAM_PORT:-80}:80"   # Change IPAM_PORT in .env to use different port

  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: ipam_pgadmin
    restart: unless-stopped
    environment:
      PGADMIN_DEFAULT_EMAIL:    ${PGADMIN_EMAIL:-admin@ipam.local}
      PGADMIN_DEFAULT_PASSWORD: ${PGADMIN_PASSWORD:-admin}
    ports:
      - "5050:80"
    depends_on:
      - db
    profiles:
      - dev

volumes:
  postgres_data:
